---
import { Button } from "@/components/starwind/button";
import {
  Card,
  CardAction,
  CardDescription,
  CardFooter,
  CardHeader,
  CardTitle,
} from "@/components/starwind/card";
import { Badge } from "@/components/starwind/badge";

const {project} = Astro.props
---

<Card class="relative mx-auto w-full max-w-sm">
    <img
        src={project.data.imageUrl}
        alt={project.data.title}
        class="h-48 w-full object-cover rounded-t-md"
    />

    <CardHeader>
        <CardAction>
            {project.data.apps.map((app: any) =>
                <Badge size="sm" variant="info">{app}</Badge>
                )
            }
        </CardAction> 

        <CardTitle>{project.data.title}</CardTitle>

        <CardDescription>
            {project.data.description}
            <p>{project.data.published}</p>
        </CardDescription>
    </CardHeader>

    <CardFooter>
        <Button class="w-full" href={`/articles/${project.data.slug}`}>View</Button>
    </CardFooter>
  </Card>