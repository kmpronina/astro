---
import { getCollection } from 'astro:content';
import ProjectCard from '../cards/ProjectCard.astro';

const articles = await getCollection('articles');
---

<h1 class="text-2xl font-bold py-2">My Articles</h1>

<ul class="grid grid-col-1 md:grid-cols-3 gap-2">
  {articles.map((article:any) => <ProjectCard project={article} />)}
</ul>